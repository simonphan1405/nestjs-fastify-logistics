generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ShipStatus {
  IDLE
  LOADING
  SAILING
  MAINTENANCE
}

enum ShipmentStatus {
  PENDING
  LOADING
  SAILING
  DELIVERED
}

model Port {
  id        String   @id @default(uuid())
  name      String   @unique
  country   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ports")
}

model Ship {
  id        String   @id @default(uuid())
  name      String   @unique
  captain   String
  capacity  Int
  status    ShipStatus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ships")
}

model Shipment {
  id                 String   @id @default(uuid())
  cargoName          String
  weight             Int
  originPortId       String
  destinationPortId  String
  shipId             String?
  status             ShipmentStatus
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("shipments")
}